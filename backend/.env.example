# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL
# Production (Render): set a single DATABASE_URL connection string. When present
# it takes precedence over the PG* values and SSL is enabled automatically.
# DATABASE_URL=postgres://user:password@host:5432/diskitrack
PGHOST=localhost
PGPORT=5432
PGDATABASE=diskitrack
PGUSER=postgres
PGPASSWORD=postgres

# JWT
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Optional: skip demo seed during `npm run setup-db`
# SKIP_SEED=false
