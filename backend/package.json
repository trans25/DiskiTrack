{
  "name": "diskitrack-backend",
  "version": "1.0.0",
  "description": "DiskiTrack multi-tenant football analytics API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup-db": "node src/scripts/setupDb.js",
    "seed-demo": "node src/scripts/seedDemo.js",
    "migrate": "psql -d $PGDATABASE -f src/db/schema.sql",
    "seed": "psql -d $PGDATABASE -f src/db/seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
