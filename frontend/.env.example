# Local development defaults.
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000

# Production (set these in the Vercel project's Environment Variables, then
# redeploy — Vite inlines them at build time, so a rebuild is required):
#   VITE_API_URL=https://diskitrack-api.onrender.com/api   (note the /api suffix)
#   VITE_SOCKET_URL=https://diskitrack-api.onrender.com     (bare origin, no path)
# Also set CLIENT_ORIGIN=<your Vercel URL> on the Render backend so CORS allows it.
