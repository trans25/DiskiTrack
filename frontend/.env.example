# Environment variables for the frontend (Vite).
#
# Vite automatically loads the right file per command — you never need to edit
# URLs when switching environments:
#   npm run dev    -> loads .env.development  (local backend)
#   npm run build  -> loads .env.production   (deployed backend)
#
# .env (this name) is loaded in ALL modes and can hold shared overrides.
# Copy this file to create your own if needed.
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
